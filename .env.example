# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs Stripe — générés automatiquement par npm run stripe:sync
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_SEMESTER=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_SEMESTER=price_...

# URL publique RÉELLE du site (ne pas laisser l'exemple « votre-domaine.com »).
# Local :
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Prod Vercel (variable à définir sur le dashboard Vercel, pas en local) :
# NEXT_PUBLIC_APP_URL=https://buildrai-xi.vercel.app

# Admin — emails autorisés (séparés par des virgules) pour /admin et bypass abonnement
ADMIN_EMAILS=votre@email.com

# OpenAI (coach IA)
OPENAI_API_KEY=sk-...
# gpt-4o = plus compétent | gpt-4o-mini = moins cher
OPENAI_MODEL=gpt-4o
